# E2E test environment — copy to .env.e2e and fill in real values
# NEVER commit .env.e2e to version control (it is listed in .gitignore)

# ----- Supabase connection -----
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key — only needed if tests call Admin API directly
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ----- Application base URL (used by playwright.config.ts) -----
E2E_BASE_URL=http://localhost:5173

# ----- Admin credentials (must be a real user with role=admin in the DB) -----
E2E_ADMIN_EMAIL=admin@tacf.mil.br
E2E_ADMIN_PASSWORD=CHANGE_ME

# ----- Regular user credentials (must be a real user with no admin role) -----
E2E_USER_EMAIL=usuario@tacf.mil.br
E2E_USER_PASSWORD=CHANGE_ME
