# Local env template
# Copy to .env (do NOT commit sensitive values)

# Postgres connection string used by scripts (use Supabase connection string for a dedicated admin user)
# Example: postgres://postgres:password@db.host.supabase.co:5432/postgres
DATABASE_URL=

# Client-side values (used by the app via import.meta.env)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
