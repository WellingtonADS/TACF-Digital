{
  "name": "tacf-digital",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "db:apply": "node scripts/db/applyMigrations.cjs",
    "db:seed": "node scripts/db/applyMigrations.cjs --seed",
    "db:check": "node scripts/db/runRpcChecks.cjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:integration": "vitest run",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:headed": "playwright test -c playwright.config.ts --headed",
    "test:e2e:admin-context": "playwright test -c playwright.config.ts tests/e2e/admin-context.routes.spec.ts",
    "test:e2e:admin-context:headed": "playwright test -c playwright.config.ts tests/e2e/admin-context.routes.spec.ts --headed",
    "test:e2e:admin-context:auth": "playwright test -c playwright.config.ts tests/e2e/admin-context.routes.spec.ts --grep \"acesso autenticado\"",
    "test:e2e:admin-context:auth:headed": "playwright test -c playwright.config.ts tests/e2e/admin-context.routes.spec.ts --grep \"acesso autenticado\" --headed",
    "test:e2e:user-context": "playwright test -c playwright.config.ts tests/e2e/user-context.routes.spec.ts",
    "test:e2e:user-context:headed": "playwright test -c playwright.config.ts tests/e2e/user-context.routes.spec.ts --headed",
    "test:e2e:user-context:auth": "playwright test -c playwright.config.ts tests/e2e/user-context.routes.spec.ts --grep \"acesso autenticado\"",
    "test:e2e:user-context:auth:headed": "playwright test -c playwright.config.ts tests/e2e/user-context.routes.spec.ts --grep \"acesso autenticado\" --headed",
    "test:e2e:admin-journey": "playwright test -c playwright.config.ts tests/e2e/admin-journey.ui.spec.ts",
    "test:e2e:admin-journey:headed": "playwright test -c playwright.config.ts tests/e2e/admin-journey.ui.spec.ts --headed",
    "test:e2e:admin-om-crud": "playwright test -c playwright.config.ts tests/e2e/admin-om-crud.observability.spec.ts",
    "test:e2e:admin-om-crud:headed": "playwright test -c playwright.config.ts tests/e2e/admin-om-crud.observability.spec.ts --headed",
    "test:e2e:admin-sessions-crud": "playwright test -c playwright.config.ts tests/e2e/admin-sessions-crud.observability.spec.ts",
    "test:e2e:admin-sessions-crud:headed": "playwright test -c playwright.config.ts tests/e2e/admin-sessions-crud.observability.spec.ts --headed",
    "test:e2e:admin-rescheduling-crud": "playwright test -c playwright.config.ts tests/e2e/admin-rescheduling-crud.observability.spec.ts",
    "test:e2e:admin-rescheduling-crud:headed": "playwright test -c playwright.config.ts tests/e2e/admin-rescheduling-crud.observability.spec.ts --headed",
    "test:e2e:admin-personnel-crud": "playwright test -c playwright.config.ts tests/e2e/admin-personnel-crud.observability.spec.ts",
    "test:e2e:admin-personnel-crud:headed": "playwright test -c playwright.config.ts tests/e2e/admin-personnel-crud.observability.spec.ts --headed",
    "test:e2e:admin-settings-profiles-crud": "playwright test -c playwright.config.ts tests/e2e/admin-settings-profiles-crud.observability.spec.ts",
    "test:e2e:admin-settings-profiles-crud:headed": "playwright test -c playwright.config.ts tests/e2e/admin-settings-profiles-crud.observability.spec.ts --headed",
    "test:e2e:admin-audit": "playwright test -c playwright.config.ts tests/e2e/admin-audit.observability.spec.ts",
    "test:e2e:admin-audit:headed": "playwright test -c playwright.config.ts tests/e2e/admin-audit.observability.spec.ts --headed",
    "test:e2e:admin-analytics": "playwright test -c playwright.config.ts tests/e2e/admin-analytics.observability.spec.ts",
    "test:e2e:admin-analytics:headed": "playwright test -c playwright.config.ts tests/e2e/admin-analytics.observability.spec.ts --headed",
    "test:e2e:user-crud": "playwright test -c playwright.config.ts tests/e2e/user-crud.observability.spec.ts",
    "test:e2e:user-crud:headed": "playwright test -c playwright.config.ts tests/e2e/user-crud.observability.spec.ts --headed",
    "test:e2e:user-crud:reschedule": "playwright test -c playwright.config.ts tests/e2e/user-crud.observability.spec.ts --grep \"reagendamento-condicional\"",
    "test:e2e:user-crud:reschedule:headed": "playwright test -c playwright.config.ts tests/e2e/user-crud.observability.spec.ts --grep \"reagendamento-condicional\" --headed"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.574.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.2.3",
    "eslint": "^10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^27.4.0",
    "pg": "^8.17.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.55.0",
    "vite": "^5.0.8",
    "vitest": "^4.0.18",
    "axe-core": "^5.0.0",
    "jest-axe": "^7.1.1",
    "@axe-core/playwright": "^4.0.0"
  }
}
